{
  "name": "neo-editor",
  "version": "1.0.0",
  "description": "Professional SQL Editor with AI debugging, multi-database support, and zero-setup experience",
  "main": "electron-main.js",
  "author": "Neo Editor Team",
  "license": "MIT",
  "homepage": "https://github.com/Neo-Editor/Neo-Editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/Neo-Editor/Neo-Editor.git"
  },
  "scripts": {
    "electron": "electron .",
    "electron-dev": "ELECTRON_START_URL=http://localhost:3000 electron .",
    "electron-pack": "electron-builder --win --x64",
    "electron-pack-linux": "electron-builder --linux appimage",
    "electron-pack-mac": "electron-builder --mac",
    "electron-pack-all": "electron-builder --win --linux --mac",
    "release": "electron-builder --win --linux --mac --publish never"
  },
  "build": {
    "appId": "com.neoeditor.app",
    "productName": "Neo Editor",
    "copyright": "Copyright © 2026 Neo Editor Team",
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico",
      "artifactName": "Neo-Editor-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development",
      "icon": "build/icon.png",
      "artifactName": "Neo-Editor-${version}.${ext}"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "artifactName": "Neo-Editor-${version}.${ext}"
    },
    "files": [
      "build/**/*",
      "backend/**/*",
      "electron-main.js",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.0"
  }
}
